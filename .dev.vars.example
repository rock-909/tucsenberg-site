# Cloudflare Workers 本地开发环境变量
# Cloudflare local preview minimal example.
# 复制此文件为 .dev.vars 并填入实际值
# .dev.vars 已在 .gitignore 中，不会被提交
#
# This file is only the local Workers preview surface. Use .env.example and
# docs/项目基础/部署.md as the full env contract, then copy only the
# server-only values needed for the preview you are actually testing.

NODE_ENV=development
NEXTJS_ENV=development
NEXT_PUBLIC_BASE_URL=http://localhost:8787
NEXT_PUBLIC_DEPLOYMENT_PLATFORM=cloudflare
DEPLOYMENT_PLATFORM=cloudflare

# Lead path values. Copy from .env.local, Cloudflare dashboard, or secrets.
# RESEND_API_KEY=
# AIRTABLE_API_KEY=
# AIRTABLE_BASE_ID=
# AIRTABLE_TABLE_NAME=
# TURNSTILE_SECRET_KEY=
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Runtime security and Cloudflare compatibility values.
# Keep these server-only unless the key explicitly starts with NEXT_PUBLIC_.
# RATE_LIMIT_PEPPER=
# RATE_LIMIT_PEPPER_PREVIOUS=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Optional owner dashboard / analytics values for local dashboard checks.
# CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_ANALYTICS_API_TOKEN=
# CLOUDFLARE_ANALYTICS_HOSTNAME=
# OPS_DASHBOARD_ACCESS_KEY=
