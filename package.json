{
  "name": "tucsenberg-site",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11.1.0 <12"
  },
  "packageManager": "pnpm@11.1.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "type-check": "next typegen && tsc --noEmit",
    "lint:check": "eslint . --ext .js,.jsx,.ts,.tsx --config eslint.config.mjs --cache --cache-location .eslintcache --max-warnings 0 && node scripts/starter-checks.js eslint-disable",
    "knip:check": "knip",
    "react:doctor": "npx --loglevel=error -y react-doctor@latest --verbose --scope changed --blocking error",
    "react:doctor:report": "npx --loglevel=error -y react-doctor@latest --json --no-score --blocking none",
    "release:verify": "node scripts/starter-checks.js release-verify",
    "website:check": "pnpm type-check && pnpm lint:check && pnpm test && pnpm build",
    "website:build:cf": "pnpm exec opennextjs-cloudflare build",
    "website:build:cf:debug": "pnpm exec opennextjs-cloudflare build --noMinify",
    "website:lighthouse": "lhci autorun --config=./lighthouserc.js",
    "brand:check": "node scripts/starter-checks.js brand",
    "content:check": "node scripts/starter-checks.js content-manifest --check && node scripts/starter-checks.js content-slugs && node scripts/starter-checks.js translations && node scripts/starter-checks.js message-key-usage",
    "messages:sync": "tsx scripts/quality/sync-message-compat.ts",
    "component:governance:test": "pnpm exec vitest run tests/architecture/component-governance.test.ts tests/architecture/ui-component-index.test.ts tests/unit/scripts/component-governance-check.test.ts",
    "component:governance": "node scripts/starter-checks.js component-governance",
    "component:check": "pnpm component:governance:test && pnpm component:governance && pnpm exec storybook build"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.5.3",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "16.2.7",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-radio-group": "^1.4.0",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-slot": "1.2.5",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tailwindcss/typography": "^0.5.20",
    "@types/mdx": "^2.0.14",
    "airtable": "0.12.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "next": "16.2.7",
    "next-intl": "^4.13.0",
    "next-themes": "0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@babel/parser": "^7.29.7",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/compat": "2.1.0",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "16.2.7",
    "@next/eslint-plugin-next": "16.2.7",
    "@opennextjs/cloudflare": "1.19.11",
    "@playwright/test": "^1.60.0",
    "@storybook/nextjs-vite": "^10.4.6",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.8",
    "axe-core": "^4.12.0",
    "dependency-cruiser": "^17.4.3",
    "dotenv": "17.4.2",
    "eslint": "^10.4.1",
    "eslint-config-next": "^16.2.7",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-you-might-not-need-an-effect": "1.0.0",
    "eslint-plugin-security": "4.0.1",
    "fast-check": "^4.8.0",
    "glob": "^13.0.6",
    "js-yaml": "^4.2.0",
    "jsdom": "^29.1.1",
    "knip": "^6.24.0",
    "lefthook": "2.1.9",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "remark-frontmatter": "^5.0.0",
    "sharp": "^0.34.5",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.61.0",
    "vite": "8.0.16",
    "vitest": "^4.1.8",
    "wrangler": "4.100.0"
  }
}
